# LLM Configuration
# Choose one of: google, openai, anthropic
LLM_PROVIDER=openai

# Choose a model appropriate for the provider:
# For google: gemini-2.5-flash or gemini-1.5-pro
# For openai: gpt-4o or gpt-4o-mini
# For anthropic: claude-3-5-sonnet-latest
LLM_MODEL=gpt-5.6-luna

# API Keys (fill in the one you use)
GOOGLE_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Bot Settings
# Set to 'true' to let the bot click the submit button itself.
# Set to 'false' to fill the application but let you review and submit manually.
AUTO_SUBMIT=true

# Browser Settings
# Set to 'true' to run browser in background.
# Set to 'false' to see the browser window and watch the bot apply.
HEADLESS=false
